# Extends the official Airflow image with the two things our DAG needs
# that aren't there by default: the psql client, and dbt.
FROM apache/airflow:2.9.3

USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends postgresql-client \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

USER airflow
RUN pip install --no-cache-dir dbt-core==1.8.* dbt-postgres==1.8.* faker
